@startuml
 
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 60
 
abstract class Register {
    # value : int
    + Register()
    + ~Register()
    + getValue() : int
    + setValue(v : int) : void
}
 
class GeneralRegister {
    - name : string
    + GeneralRegister(n : string)
    + getValue() : int
    + setValue(v : int) : void
    + print() : void
}
 
class FlagRegister {
    - CF : bool
    - ZF : bool
    - OF : bool
    - UF : bool
    + setFlags(result : int, op1 : int, op2 : int) : void
    + getCF() : bool
    + getZF() : bool
    + getOF() : bool
    + getUF() : bool
    + print() : void
}
 
Register <|-- GeneralRegister
Register <|-- FlagRegister
 
class Memory {
    - memory_map : int[64]
    + Memory()
    + read(addr : int) : int
    + write(addr : int, val : int) : void
    + print() : void
}
 
class CPU {
    - pc : int
    + CPU()
    + fetch() : void
    + decode() : void
    + execute() : void
    + getPC() : int
    + incrementPC() : void
}
 
class VirtualMachine {
    - cpu : CPU
    - memory : Memory
    - flags : FlagRegister
    - registers : CustomVector
    + VirtualMachine()
    + getCPU() : CPU
    + getRegister(idx : int) : GeneralRegister
    + getFlags() : FlagRegister
    + getMemory() : Memory
    + printState() : void
}
 
class CustomVector {
    - data : T[]
    - size : int
    - capacity : int
    + push_back(item : T) : void
    + get(index : int) : T
    + size() : int
    + isEmpty() : bool
}
 
class CustomStack {
    - data : T[]
    - top : int
    + push(item : T) : void
    + pop() : T
    + peek() : T
    + isEmpty() : bool
}
 
class CustomQueue {
    - data : T[]
    - front : int
    - rear : int
    + enqueue(item : T) : void
    + dequeue() : T
    + isEmpty() : bool
}
 
abstract class Instruction {
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
abstract class ArithmeticInstruction {
    # destReg : int
    # srcVal : int
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
abstract class ShiftInstruction {
    # registerNum : int
    # amount : int
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
abstract class IOInstruction {
    # registerNum : int
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
abstract class MoveInstruction {
    # rDest : int
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
abstract class StackInstruction {
    # registerNum : int
    + execute(vm : VirtualMachine) : void
    + getName() : string
}
 
class AddInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class SubInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class MulInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class DivInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class IncInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class DecInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class ShlInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class ShrInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class RolInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class RorInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class InputInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class DisplayInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class LoadRegInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class LoadMemInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class StoreRegInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class StoreMemInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class MovRegRegInstruction {
    - rSrc : int
    + execute(vm : VirtualMachine) : void
}
 
class MovImmInstruction {
    - immediateValue : int
    + execute(vm : VirtualMachine) : void
}
 
class MovIndirectInstruction {
    - rSrc : int
    + execute(vm : VirtualMachine) : void
}
 
class ResetInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class PushInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class PopInstruction {
    + execute(vm : VirtualMachine) : void
}
 
class Runner {
    - vm : VirtualMachine
    - rawLines : CustomVector
    - program : CustomQueue
    + loadProgram(filename : string) : void
    + parseProgram() : void
    + run() : void
    + ~Runner()
}
 
Instruction <|-- ArithmeticInstruction
Instruction <|-- ShiftInstruction
Instruction <|-- IOInstruction
Instruction <|-- MoveInstruction
Instruction <|-- StackInstruction
Instruction <|-- ResetInstruction
 
ArithmeticInstruction <|-- AddInstruction
ArithmeticInstruction <|-- SubInstruction
ArithmeticInstruction <|-- MulInstruction
ArithmeticInstruction <|-- DivInstruction
ArithmeticInstruction <|-- IncInstruction
ArithmeticInstruction <|-- DecInstruction
 
ShiftInstruction <|-- ShlInstruction
ShiftInstruction <|-- ShrInstruction
ShiftInstruction <|-- RolInstruction
ShiftInstruction <|-- RorInstruction
 
IOInstruction <|-- InputInstruction
IOInstruction <|-- DisplayInstruction
IOInstruction <|-- LoadRegInstruction
IOInstruction <|-- LoadMemInstruction
IOInstruction <|-- StoreRegInstruction
IOInstruction <|-- StoreMemInstruction
 
MoveInstruction <|-- MovRegRegInstruction
MoveInstruction <|-- MovImmInstruction
MoveInstruction <|-- MovIndirectInstruction
 
StackInstruction <|-- PushInstruction
StackInstruction <|-- PopInstruction
 
VirtualMachine *-- CPU
VirtualMachine *-- Memory
VirtualMachine *-- FlagRegister
VirtualMachine *-- GeneralRegister
VirtualMachine *-- CustomVector
 
CPU *-- CustomStack
 
Runner *-- VirtualMachine
Runner *-- CustomVector
Runner *-- CustomQueue
Runner o-- Instruction
 
@enduml
